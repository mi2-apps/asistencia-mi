{
  "name": "stack-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MI Apps stack template — passes 8/8 conformance. Clone, rename, push.",
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "pm2-runtime ecosystem.config.cjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "drizzle-orm": "^0.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "pm2": "^5.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.23.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "engines": { "node": ">=20" }
}
