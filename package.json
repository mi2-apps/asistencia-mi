{
  "name": "asistencia-mi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Sistema de Control de Asistencia — MI Technologies",
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "pm2-runtime ecosystem.config.cjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx server/db/migrate.ts",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "drizzle-orm": "^0.32.0",
    "drizzle-zod": "^0.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "pm2": "^5.4.2",
    "passport": "^0.7.0",
    "passport-openidconnect": "^0.1.2",
    "express-session": "^1.18.0",
    "connect-pg-simple": "^10.0.0",
    "bcrypt": "^6.0.0",
    "multer": "^2.0.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "express-rate-limit": "^8.0.0",
    "cors": "^2.8.5",
    "zod": "^3.23.8",
    "react-hook-form": "^7.52.0",
    "@hookform/resolvers": "^3.6.0",
    "@tanstack/react-query": "^5.51.0",
    "zustand": "^4.5.4",
    "wouter": "^3.3.0",
    "lucide-react": "^0.395.0",
    "i18next": "^23.12.0",
    "react-i18next": "^14.1.3",
    "i18next-http-backend": "^2.5.2",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/passport": "^1.0.16",
    "@types/passport-openidconnect": "^0.1.3",
    "@types/express-session": "^1.18.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^1.4.11",
    "@types/morgan": "^1.9.9",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.23.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "engines": { "node": ">=20" }
}
