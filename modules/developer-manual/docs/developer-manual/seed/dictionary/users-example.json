        { "name": "role", "type": "varchar(20)", "nullable": false, "meaning": "Access level — what the user may do", "references": null, "allowedValues": "admin | supervisor | user", "notes": "drives RBAC" },
        { "name": "created_at", "type": "timestamp", "nullable": true, "meaning": "When the account was created", "references": null, "allowedValues": null, "notes": "defaults to now()" }
      ],
      "foreignKeys": [],
      "sampleQueries": [
        { "description": "All admins", "sql": "SELECT id, username FROM users WHERE role = 'admin';" },
