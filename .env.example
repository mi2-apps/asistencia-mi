# Database
DATABASE_URL=postgresql://user:password@localhost:5432/asistencia_mi

# Session
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Nextcloud OIDC (run `provision-app-sso asistencia-mi` on COOLIFY-01 to get these)
OIDC_ISSUER_URL=https://cloud.miglobal.com.mx
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# App
PORT=3000
NODE_ENV=development
